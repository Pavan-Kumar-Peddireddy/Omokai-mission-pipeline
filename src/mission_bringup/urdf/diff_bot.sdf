<?xml version="1.0" ?>
<sdf version="1.7">
  <model name="diff_bot">
    <static>false</static>

    <link name="base_footprint"/>

    <link name="base_link">
      <pose relative_to="base_footprint">0 0 0.07 0 0 0</pose>
      <inertial>
        <pose>0 0 0.12 0 0 0</pose>
        <mass>15.0</mass>
        <inertia>
          <ixx>0.6</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.6</iyy>
          <iyz>0</iyz>
          <izz>0.6</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <pose>0 0 0.12 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.25</radius>
            <length>0.24</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="base_visual">
        <pose>0 0 0.12 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.25</radius>
            <length>0.24</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.8 0.8</ambient>
          <diffuse>0.1 0.1 0.8 0.8</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>
    </link>

    <joint name="base_footprint_joint" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
    </joint>

    <link name="left_wheel">
      <pose relative_to="left_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>1.5</mass>
        <inertia>
          <ixx>0.01</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.01</iyy><iyz>0</iyz>
          <izz>0.01</izz>
        </inertia>
      </inertial>
      <collision name="left_wheel_collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.07</radius>
            <length>0.035</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
          </friction>
        </surface>
      </collision>
      <visual name="left_wheel_visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.07</radius>
            <length>0.035</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <pose relative_to="base_link">0 0.2675 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <link name="right_wheel">
      <pose relative_to="right_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>1.5</mass>
        <inertia>
          <ixx>0.01</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.01</iyy><iyz>0</iyz>
          <izz>0.01</izz>
        </inertia>
      </inertial>
      <collision name="right_wheel_collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.07</radius>
            <length>0.035</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
          </friction>
        </surface>
      </collision>
      <visual name="right_wheel_visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.07</radius>
            <length>0.035</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="right_wheel_joint" type="revolute">
      <pose relative_to="base_link">0 -0.2675 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <link name="front_support">
      <pose relative_to="front_support_joint">0 0 -0.03 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0001</iyy><iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <collision name="front_support_collision">
        <geometry><sphere><radius>0.04</radius></sphere></geometry>
        <surface>
          <friction>
            <ode><mu>0.1</mu><mu2>0.1</mu2></ode>
          </friction>
        </surface>
      </collision>
      <visual name="front_support_visual">
        <geometry><sphere><radius>0.04</radius></sphere></geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="front_support_joint" type="fixed">
      <pose relative_to="base_link">0.2 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>front_support</child>
    </joint>

    <link name="back_support">
      <pose relative_to="back_support_joint">0 0 -0.03 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0001</iyy><iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <collision name="back_support_collision">
        <geometry><sphere><radius>0.04</radius></sphere></geometry>
        <surface>
          <friction>
            <ode><mu>0.1</mu><mu2>0.1</mu2></ode>
          </friction>
        </surface>
      </collision>
      <visual name="back_support_visual">
        <geometry><sphere><radius>0.04</radius></sphere></geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="back_support_joint" type="fixed">
      <pose relative_to="base_link">-0.2 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>back_support</child>
    </joint>

    <link name="lidar_link">
      <pose relative_to="lidar_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0001</iyy><iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <visual name="lidar_visual">
        <geometry><cylinder><radius>0.03</radius><length>0.03</length></cylinder></geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>
      <collision name="lidar_collision">
        <geometry><cylinder><radius>0.03</radius><length>0.03</length></cylinder></geometry>
      </collision>
      <sensor name="rplidar" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>640</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.1</min>
            <max>10.0</max>
          </range>
        </lidar>
        <always_on>1</always_on>
        <visualize>true</visualize>
        <topic>/scan</topic>
      </sensor>
    </link>

    <joint name="lidar_joint" type="fixed">
    
      <pose relative_to="base_link">0.22 0 0.24 0 0 0</pose>
      <parent>base_link</parent>
      <child>lidar_link</child>
    </joint>

    <!-- <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre</render_engine>
    </plugin> -->

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.535</wheel_separation>
      <wheel_radius>0.07</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <cmd_vel_topic>/cmd_vel</cmd_vel_topic>
      <odom_topic>/odom</odom_topic>
      <odometry_frame>odom</odometry_frame>
      <base_frame>base_footprint</base_frame>
      <!-- <tf_topic>/tf</tf_topic> -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
      <joint_name>left_wheel_joint</joint_name> <!-- Change to your exact left wheel joint name -->
      <joint_name>right_wheel_joint</joint_name>
    </plugin>

  </model>
</sdf>