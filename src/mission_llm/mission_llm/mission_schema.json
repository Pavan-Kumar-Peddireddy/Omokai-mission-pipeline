{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MissionPlan",
  "type": "object",
  "required": ["mission_id", "command", "waypoints", "loops", "max_speed", "frame_id"],
  "additionalProperties": false,
  "properties": {
    "mission_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "command": {
      "type": "string",
      "enum": ["patrol_loop", "goto_waypoints", "return_to_start"]
    },
    "waypoints": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["x", "y", "yaw"],
        "additionalProperties": false,
        "properties": {
          "x":   {"type": "number", "minimum": -50, "maximum": 50},
          "y":   {"type": "number", "minimum": -50, "maximum": 50},
          "yaw": {"type": "number", "minimum": -3.15, "maximum": 3.15}
        }
      }
    },
    "loops": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "max_speed": {
      "type": "number",
      "minimum": 0.05,
      "maximum": 1.0
    },
    "frame_id": {
      "type": "string",
      "enum": ["map"]
    },
    "notes": {
      "type": "string",
      "maxLength": 200
    }
  }
}
